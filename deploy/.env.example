# Required — the GitHub user/org that owns the GHCR images.
# Examples: GHCR_OWNER=florisheyvaert
GHCR_OWNER=

# Required — Postgres password used by both the db and api services.
POSTGRES_PASSWORD=change-me

# Image tag to pull. develop branch publishes :preview, main publishes :latest.
TAG=latest

# Host port that serves the web UI (proxies /api to the api container internally).
WEB_PORT=8080

# ── External OIDC login (optional) ───────────────────────────────────────────
# Leave these blank to disable external login — local email/password keeps working.
# The API registers a provider only when SCHEME, AUTHORITY and CLIENT_ID are all set.
#
# After filling these in, register this redirect URI in your provider (Authentik):
#   https://<your-public-host>/api/auth/<OIDC_SCHEME>/signin-callback
#   e.g. https://cookmate.example.com/api/auth/authentik/signin-callback
#
# Note: the public host must be reachable over https and your TLS-terminating proxy
# must forward X-Forwarded-Proto/Host (the API honours them) so the redirect URI the
# provider receives matches the one registered above.
#
# Scheme is a URL-safe key (also used in the redirect path). DisplayName is the button label.
OIDC_SCHEME=authentik
OIDC_DISPLAY_NAME=Authentik
# Issuer/authority URL of your provider's application (note the trailing slash).
OIDC_AUTHORITY=https://auth.example.com/application/o/cookmate/
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
